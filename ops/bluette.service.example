[Unit]
Description=Bluette Server
After=network.target

[Service]
Type=simple
User=bluette
Group=bluette
WorkingDirectory=/opt/bluette_server
EnvironmentFile=/etc/bluette/bluette.env
ExecStart=/usr/bin/env mix run --no-halt
Restart=always
RestartSec=5
NoNewPrivileges=true
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target